# ZPA Status Mini-SIEM Configuration
# Generated by install.sh — edit manually or re-run: install.sh --configure
#
# This file controls all runtime settings for the ZPA Mini-SIEM system.
# After editing, restart affected services:
#   systemctl restart zpa-report.timer    (if schedule changed)
#   systemctl restart zpa-dashboard       (if dashboard settings changed)

[general]
# IANA timezone for report timestamps (e.g., Europe/Rome, America/New_York, UTC)
# Full list: python3 -c "import zoneinfo; print(sorted(zoneinfo.available_timezones()))"
timezone = UTC
# Ignore logs from clients with major version above this value (0 = no filter)
# Useful to filter out VM noise (e.g., version 25.x) while keeping real clients (e.g., 4.x)
max_client_version = 10

[syslog]
# Syslog reception port (typically 514)
port = 514
# Protocol: tcp or udp
protocol = tcp
# Directory where rsyslog writes ZPA log files
log_dir = /var/log/zpa

[reports]
# Directory for generated Excel and JSON reports
output_dir = /opt/zpa-siem/reports
# Daily report generation time (fixed at 00:05 for midnight-to-midnight coverage)
schedule = 00:05
# Number of days to keep generated reports (older reports are auto-deleted)
retention_days = 180
# Report filename template. {date} is replaced with YYYY-MM-DD
filename_pattern = zpa-report-{date}

[dashboard]
# Enable or disable the web dashboard (true/false)
enabled = true
# HTTPS port for the web dashboard
port = 8443
# Login username
username = admin
# Bcrypt-hashed password (generated by install.sh, do not edit manually)
# To change: run install.sh --configure
password_hash =
# Session timeout in minutes (0 = no timeout)
session_timeout = 30

[share]
# Enable or disable automatic report upload to a file share (true/false)
enabled = false
# Upload method: smb or scp
method = smb
# File format to upload: xlsx or csv
format = xlsx
# --- SMB settings (used when method = smb) ---
# UNC path to the share (e.g., //fileserver/reports/zpa)
smb_share =
# SMB username
smb_username =
# SMB password
smb_password =
# SMB domain (optional, leave empty if not needed)
smb_domain =
# --- SCP settings (used when method = scp) ---
# SCP target in user@host:/path format
scp_target =
